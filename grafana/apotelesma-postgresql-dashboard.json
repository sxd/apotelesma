{
  "__inputs": [
    {
      "name": "DS_POSTGRES",
      "label": "PostgreSQL",
      "description": "PostgreSQL datasource pointing at the Apotelesma analytics database",
      "type": "datasource",
      "pluginId": "grafana-postgresql-datasource",
      "pluginName": "PostgreSQL"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(commit_day::timestamp, $__interval),\n  sum(commit_count) AS value,\n  branch AS metric\nFROM daily_activity\nWHERE $__timeFilter(commit_day::timestamp)\nGROUP BY 1, 3\nORDER BY 1, 3",
          "refId": "A"
        }
      ],
      "title": "Daily Commit Count By Branch",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(commit_day::timestamp, $__interval),\n  sum(total_insertions) AS value,\n  branch AS metric\nFROM daily_activity\nWHERE $__timeFilter(commit_day::timestamp)\nGROUP BY 1, 3\nORDER BY 1, 3",
          "refId": "A"
        }
      ],
      "title": "Daily Insertions By Branch",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "id": 3,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "enablePagination": true,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  branch,\n  count(*) AS commit_count,\n  count(DISTINCT author_email) AS author_count,\n  min(author_date) AS first_commit_at,\n  max(author_date) AS last_commit_at,\n  sum(insertions) AS total_insertions,\n  sum(deletions) AS total_deletions,\n  sum(changed_files) AS total_changed_files\nFROM commits\nWHERE $__timeFilter(author_date)\nGROUP BY branch\nORDER BY commit_count DESC, branch",
          "refId": "A"
        }
      ],
      "title": "Branch Summary",
      "type": "table"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 8,
        "y": 10
      },
      "id": 4,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "enablePagination": true,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  branch,\n  author_name,\n  author_email,\n  count(*) AS commit_count,\n  sum(insertions) AS total_insertions,\n  sum(deletions) AS total_deletions,\n  sum(changed_files) AS total_changed_files,\n  max(author_date) AS last_commit_at\nFROM commits\nWHERE $__timeFilter(author_date)\nGROUP BY branch, author_name, author_email\nORDER BY commit_count DESC, last_commit_at DESC, author_email\nLIMIT 250",
          "refId": "A"
        }
      ],
      "title": "Top Authors",
      "type": "table"
    },
    {
      "datasource": {
        "type": "grafana-postgresql-datasource",
        "uid": "${DS_POSTGRES}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "id": 5,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "enablePagination": true,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  author_date AS \"time\",\n  branch,\n  author_name,\n  summary,\n  insertions,\n  deletions,\n  changed_files\nFROM commits\nWHERE $__timeFilter(author_date)\nORDER BY author_date DESC\nLIMIT 250",
          "refId": "A"
        }
      ],
      "title": "Recent Commits",
      "type": "table"
    }
  ],
  "refresh": "30m",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "postgresql",
    "git",
    "ekorre",
    "sql"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-90d",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Apotelesma PostgreSQL Dashboard",
  "uid": "apotelesma-postgresql",
  "version": 1,
  "weekStart": ""
}
